<?xml version="1.0" encoding="utf-8"?>
<!-- Debug builds only. Cleartext is allowed ONLY for the emulator's host
     alias and the dev machine's LAN IP — never as a blanket policy. Update
     the LAN IP if the dev machine's address changes (see README). -->
<network-security-config>
    <base-config cleartextTrafficPermitted="false" />
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">192.168.18.12</domain>
    </domain-config>
</network-security-config>
