<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Android 11+ package visibility: without this, resolving/launching the
         system camera via ACTION_IMAGE_CAPTURE is silently BLOCKED (seen as
         an AppsFilter "BLOCKED" logcat line, camera never opens). This only
         declares visibility of camera apps — it is NOT the CAMERA permission;
         the app never accesses the camera hardware itself. -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
    </queries>

    <!-- No networkSecurityConfig here: release builds keep Android's default
         (cleartext HTTP blocked entirely, HTTPS only). The debug build type
         overlays src/debug/AndroidManifest.xml to allow cleartext for the
         local dev server hosts only. -->
    <application
        android:name=".FacturasApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.FacturasFamilia">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>
</manifest>
