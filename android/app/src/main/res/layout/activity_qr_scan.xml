<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Cutout-style frame guide only — decoding runs on the full analysis
         frame, not just this box. It exists to tell the user where to aim,
         nothing more. -->
    <View
        android:id="@+id/scan_frame"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_gravity="center"
        android:background="@drawable/qr_scan_frame" />

    <TextView
        android:id="@+id/scan_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="140dp"
        android:gravity="center"
        android:paddingHorizontal="24dp"
        android:text="@string/qr_scan_hint"
        android:textColor="@color/white"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/scan_error"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="140dp"
        android:background="#CC1B263B"
        android:gravity="center"
        android:padding="16dp"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:visibility="gone" />

    <Button
        android:id="@+id/pick_from_gallery"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="56dp"
        android:text="@string/qr_pick_from_gallery"
        android:textColor="@color/white" />

    <ImageButton
        android:id="@+id/cancel_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="@android:color/transparent"
        android:contentDescription="@string/qr_cancel"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:tint="@color/white" />

</FrameLayout>
